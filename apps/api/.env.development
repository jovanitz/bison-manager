# Local development defaults for `nx serve api` — every value here is the
# public local Supabase stack (no secrets; production config comes from real
# env vars, which always take precedence over this file).
#
# Personal overrides go in apps/api/.env (gitignored), e.g. your own
# BOOTSTRAP_OWNER_EMAIL. Omit SUPABASE_DB_URL/SUPABASE_URL to fall back to
# the in-memory dev stub (Bearer session-<preset>).

SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_URL=http://127.0.0.1:54321
# Local Supabase SECRET key (public dev value) — admin provisioning for
# invitation activation. From `supabase status`. Production: real secret env.
BOOTSTRAP_OWNER_EMAIL=owner@local.dev
# Consola de prueba en http://localhost:3333/dev (solo local)
DEV_CONSOLE=true
# Secreto local (público) del hook password_verification_attempt de GoTrue;
# debe coincidir con supabase/config.toml [auth.hook...]. Producción: env real.
AUTH_HOOK_SECRET=v1,whsec_bG9jYWwtaG9vay1zZWNyZXQtMDEyMw==
# PORT=3333
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
