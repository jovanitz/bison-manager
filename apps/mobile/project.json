{
  "name": "mobile",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/mobile/src",
  "projectType": "application",
  "tags": ["layer:app"],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint {projectRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p apps/mobile/tsconfig.app.json --noEmit"
      }
    },
    "cap:sync": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cap sync",
        "cwd": "apps/mobile"
      }
    }
  }
}
