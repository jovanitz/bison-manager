# apps/api environment — copy to `.env` (gitignored) for personal/production
# overrides. Real environment variables always win over any .env file, and
# `.env.development` (checked in) already supplies the public local-stack
# defaults, so LOCAL dev needs nothing here.
#
# In production (NODE_ENV=production) the API FAILS TO BOOT unless the values
# marked [prod-required] below are set — a missing one can never silently
# downgrade to an insecure default (see src/boot-safety.ts).

# Node environment. Set to `production` on a deployed server; the boot guard
# only enforces the requirements below when this is `production`.
NODE_ENV=development

# Postgres connection (Supabase). Omit → in-memory dev stub (NOT for prod).
# [prod-required]
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Supabase project URL. Used to verify user JWTs via its JWKS endpoint
# (asymmetric keys). Omit → dev stub where the bearer token IS the session id
# (NOT for prod). [prod-required]
SUPABASE_URL=http://127.0.0.1:54321

# Legacy alternative to SUPABASE_URL: a shared HS256 secret (min 16 chars).
# Modern Supabase uses JWKS (SUPABASE_URL); leave this unset unless you must.
# SUPABASE_JWT_SECRET=

# standard-webhooks secret of the GoTrue password_verification_attempt hook
# (records login.failed). Must match supabase/config.toml. Format: v1,whsec_<b64>.
# [prod-required] — without it the webhook would accept unsigned (forged) calls.
AUTH_HOOK_SECRET=v1,whsec_bG9jYWwtaG9vay1zZWNyZXQtMDEyMw==

# One-time owner bootstrap (ADR-0010): when no root admin exists and this email
# signs in, that identity is promoted to owner exactly once.
BOOTSTRAP_OWNER_EMAIL=owner@local.dev

# Serve the static test console at GET /dev. MUST be off in production.
DEV_CONSOLE=true

# Optional. HTTP port (default 3333).
# PORT=3333

# Optional. Comma-separated browser origins allowed on /rpc. Defaults to the
# local Vite dev ports; set to your web app's real origin(s) in production.
# CORS_ORIGINS=https://app.example.com
