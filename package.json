{
  "name": "@acme/source",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Reusable cross-platform application architecture (web, PWA, iOS, Android, Windows, macOS).",
  "packageManager": "pnpm@10.6.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test",
    "typecheck": "nx run-many -t typecheck",
    "build": "nx run-many -t build",
    "affected:lint": "nx affected -t lint",
    "affected:test": "nx affected -t test",
    "affected:typecheck": "nx affected -t typecheck",
    "affected:build": "nx affected -t build",
    "graph": "nx graph",
    "harness": "node scripts/harness/cli.mjs",
    "gate": "pnpm harness quality --build && pnpm harness structure && pnpm harness cycles && pnpm harness gaps",
    "verify": "pnpm harness e2e",
    "web": "nx serve web",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "devDependencies": {
    "@nx/eslint": "20.3.0",
    "@nx/eslint-plugin": "20.3.0",
    "@nx/js": "20.3.0",
    "@nx/react": "20.3.0",
    "@nx/vite": "20.3.0",
    "@nx/web": "20.3.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "happy-dom": "^15.0.0",
    "jsdom": "^25.0.0",
    "knip": "^6.16.1",
    "madge": "^8.0.0",
    "nx": "20.3.0",
    "prettier": "^3.3.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.20.0",
    "vite-tsconfig-paths": "^5.0.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@hookform/resolvers": "^3.9.0",
    "@tanstack/react-query": "^5.59.0",
    "dexie": "^4.0.0",
    "hono": "^4.12.25",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.53.0",
    "react-router-dom": "^6.26.0",
    "zod": "^3.23.0",
    "zustand": "^5.0.0"
  }
}
