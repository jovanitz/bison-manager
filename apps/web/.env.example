# apps/web environment (Vite). LOCAL dev needs nothing: main.tsx falls back to
# the public local-stack defaults shown below, so `pnpm web` just works.
#
# For a DEPLOYED build, set every VITE_* var to its real value at build time
# (Vite inlines them — they are public, never put secrets here). Copy to
# `.env` (gitignored) or `.env.production` and fill in real values.

# Base URL of the deployed API (the /rpc backend).
VITE_API_BASE_URL=http://localhost:3333

# Supabase project URL (the same project the API verifies tokens against).
VITE_SUPABASE_URL=http://127.0.0.1:54321

# Supabase publishable/anon key (public — safe to ship in the bundle).
VITE_SUPABASE_ANON_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH

# Optional. Shown in the UI / debug bridge.
# VITE_APP_VERSION=0.0.0
