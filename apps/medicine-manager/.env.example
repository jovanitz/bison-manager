# apps/medicine-manager environment (Vite). LOCAL dev needs nothing: main.tsx
# falls back to the public local-stack defaults below, so the dev server just
# works against `supabase start` + the local API.
#
# For a DEPLOYED build, set every VITE_* var at build time (Vite inlines them —
# they are public, never put secrets here).

# Base URL of the deployed API (the /rpc backend).
VITE_API_BASE_URL=http://localhost:3333

# Supabase project URL (the same project the API verifies tokens against).
VITE_SUPABASE_URL=http://127.0.0.1:54321

# Supabase publishable/anon key (public — safe to ship in the bundle).
VITE_SUPABASE_ANON_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH

# LOCAL-ONLY. Set to 1 to skip Supabase login and run against the API's
# dev-stub seeded world using a static bearer session (see composition-root).
# Only honored in a dev build; ignored in production. Never set when deployed.
# VITE_DEV_AUTH=1
# VITE_DEV_SESSION=session-owner

# Optional. Shown in the UI / debug bridge.
# VITE_APP_VERSION=0.0.0
