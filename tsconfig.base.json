{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "useDefineForClassFields": true,
    "baseUrl": ".",
    "paths": {
      "@acme/application": ["libs/application/src/index.ts"],
      "@acme/domain": ["libs/domain/src/index.ts"],
      "@acme/infrastructure": ["libs/infrastructure/src/index.ts"],
      "@acme/infrastructure-node": ["libs/infrastructure/src/node.ts"],
      "@acme/platform": ["libs/platform/src/index.ts"],
      "@acme/shared": ["libs/shared/src/index.ts"],
      "@acme/ui": ["libs/ui/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp", "dist"]
}
